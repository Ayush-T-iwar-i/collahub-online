{
  "expo": {
    "name": "CollaHub",
    "slug": "collahub",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "collahub",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080d17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nims.collahub"
    },
    "android": {
      "package": "com.nims.collahub",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080d17"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080d17",
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "imageWidth": 400
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedTypes": true
    },
    "updates": {
      "url": "https://u.expo.dev/666def6a-0a50-4366-b338-eb29dd5d48f3",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "666def6a-0a50-4366-b338-eb29dd5d48f3"
      }
    }
  }
}
