{
  "expo": {
    "name": "CollaHub",
    "slug": "collahub",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "collahub",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080d17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nims.collahub"
    },
    "android": {
      "package": "com.nims.collahub",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080d17"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static"
      
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080d17",
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "imageWidth": 400
        }
      ],
      "expo-video",
     [
  "expo-media-library",
  {
    "photosPermission": "Allow CollaHub to save your ID Card.",
    "savePhotosPermission": "Allow CollaHub to save your ID Card.",
    "isAccessMediaLocationEnabled": false 
  }
],
      [
        "expo-image-picker",
        {
          "photosPermission": "CollaHub needs access to your photo library to update your profile picture.",
          "cameraPermission": "CollaHub needs access to your camera to take a profile picture."
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    
    "updates": {
      "url": "https://u.expo.dev/666def6a-0a50-4366-b338-eb29dd5d48f3",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ff5b4d9b-d4d9-4128-bdb2-8d8dd07511d9"
      }
    }
  }
}
